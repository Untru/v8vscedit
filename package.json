{
  "name": "v8vscedit",
  "displayName": "Редактор конфигураций 1С",
  "description": "Редактор конфигураций и расширений 1С:Предприятие — навигация по метаданным, LSP для BSL, работа с XML-выгрузкой",
  "version": "0.3.5",
  "repository": {
    "type": "git",
    "url": "https://github.com/Macegor/v8vscedit.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onView:v8vsceditUniversal",
    "onLanguage:bsl",
    "onCommand:v8vscedit.refresh"
  ],
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "v8vscedit",
          "title": "1С: Редактор",
          "icon": "src/icons/activity-bar.svg"
        }
      ]
    },
    "views": {
      "v8vscedit": [
        {
          "id": "v8vsceditUniversal",
          "name": " ",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "v8vscedit.refresh",
        "title": "Обновить",
        "icon": "$(refresh)"
      },
      {
        "command": "v8vscedit.searchTree",
        "title": "Поиск в навигаторе",
        "icon": "$(search)"
      },
      {
        "command": "v8vscedit.clearTreeSearch",
        "title": "Сбросить поиск в навигаторе",
        "icon": "$(close)"
      },
      {
        "command": "v8vscedit.importConfigurations",
        "title": "Импортировать конфигурации из базы",
        "enablement": "!v8vscedit.isUpdatingConfigurations",
        "icon": "$(cloud-download)"
      },
      {
        "command": "v8vscedit.updateChangedConfigurations",
        "title": "Обновить изменённые конфигурации",
        "enablement": "v8vscedit.hasChangedConfigurations && !v8vscedit.isUpdatingConfigurations",
        "icon": {
          "light": "./src/icons/light/externalDataSource.svg",
          "dark": "./src/icons/dark/externalDataSource.svg"
        }
      },
      {
        "command": "v8vscedit.runThinClient",
        "title": "Запустить тонкий клиент",
        "icon": "$(run)"
      },
      {
        "command": "v8vscedit.runConfigurator",
        "title": "Запустить конфигуратор",
        "icon": "$(tools)"
      },
      {
        "command": "v8vscedit.configureEnvironment",
        "title": "Настройки проекта",
        "icon": "$(settings-gear)"
      },
      {
        "command": "v8vscedit.initializeProject",
        "title": "Инициализировать проект 1С",
        "icon": "$(new-folder)"
      },
      {
        "command": "v8vscedit.connectExtension",
        "title": "Подключить расширение",
        "icon": "$(add)"
      },
      {
        "command": "v8vscedit.installAiSkills",
        "title": "Установить ИИ-скилы 1С",
        "icon": "$(extensions)"
      },
      {
        "command": "v8vscedit.standalone.configure",
        "title": "Автономный сервер: Настроить",
        "icon": "$(settings-gear)"
      },
      {
        "command": "v8vscedit.standalone.start",
        "title": "Автономный сервер: Запустить",
        "icon": "$(run)"
      },
      {
        "command": "v8vscedit.standalone.restart",
        "title": "Автономный сервер: Перезапустить",
        "icon": "$(debug-restart)"
      },
      {
        "command": "v8vscedit.standalone.stop",
        "title": "Автономный сервер: Остановить",
        "icon": "$(debug-stop)"
      },
      {
        "command": "v8vscedit.standalone.openWebClient",
        "title": "Автономный сервер: Открыть веб-клиент",
        "icon": "$(browser)"
      },
      {
        "command": "v8vscedit.standalone.showLog",
        "title": "Автономный сервер: Открыть лог",
        "icon": "$(output)"
      },
      {
        "command": "v8vscedit.borrowToExtension",
        "title": "Добавить в расширение"
      },
      {
        "command": "v8vscedit.openXmlFile",
        "title": "Открыть XML"
      },
      {
        "command": "v8vscedit.openTemplateContent",
        "title": "Открыть содержимое макета"
      },
      {
        "command": "v8vscedit.openObjectModule",
        "title": "Открыть модуль объекта"
      },
      {
        "command": "v8vscedit.openManagerModule",
        "title": "Открыть модуль менеджера"
      },
      {
        "command": "v8vscedit.openFormModule",
        "title": "Открыть модуль формы"
      },
      {
        "command": "v8vscedit.openCommandModule",
        "title": "Открыть модуль команды"
      },
      {
        "command": "v8vscedit.openRecordSetModule",
        "title": "Открыть модуль записи"
      },
      {
        "command": "v8vscedit.openConstantModule",
        "title": "Открыть модуль константы"
      },
      {
        "command": "v8vscedit.openServiceModule",
        "title": "Открыть модуль сервиса"
      },
      {
        "command": "v8vscedit.openCommonModuleCode",
        "title": "Открыть модуль"
      },
      {
        "command": "v8vscedit.showProperties",
        "title": "Свойства",
        "icon": "$(list-unordered)"
      },
      {
        "command": "v8vscedit.addMetadata",
        "title": "Добавить",
        "icon": "$(add)"
      },
      {
        "command": "v8vscedit.removeMetadata",
        "title": "Удалить",
        "icon": "$(trash)"
      },
      {
        "command": "v8vscedit.showConfigActions",
        "title": "Команды конфигурации/расширения",
        "icon": "$(tools)"
      },
      {
        "command": "v8vscedit.importConfigurationFromDb",
        "title": "Импортировать из базы",
        "icon": "$(cloud-download)"
      },
      {
        "command": "v8vscedit.updateConfigurationInDb",
        "title": "Обновить в базе",
        "icon": "$(sync)"
      },
      {
        "command": "v8vscedit.decompileExtensionSources",
        "title": "Импортировать расширение из базы"
      },
      {
        "command": "v8vscedit.updateExtensionInDb",
        "title": "Обновить"
      },
      {
        "command": "v8vscedit.compileAndUpdateExtensionInDb",
        "title": "Полное обновление расширения в БД"
      },
      {
        "command": "v8vscedit.bslAnalyzer.showMenu",
        "title": "BSL Analyzer: Меню"
      },
      {
        "command": "v8vscedit.bslAnalyzer.restart",
        "title": "BSL Analyzer: Перезапустить"
      },
      {
        "command": "v8vscedit.bslAnalyzer.update",
        "title": "BSL Analyzer: Проверить обновления"
      },
      {
        "command": "v8vscedit.bslAnalyzer.showOutput",
        "title": "BSL Analyzer: Показать лог"
      },
      {
        "command": "v8vscedit.support.none",
        "title": "Не на поддержке",
        "icon": {
          "light": "./src/icons/light/support-none.svg",
          "dark": "./src/icons/dark/support-none.svg"
        }
      },
      {
        "command": "v8vscedit.support.editable",
        "title": "На поддержке, редактирование разрешено",
        "icon": {
          "light": "./src/icons/light/support-editable.svg",
          "dark": "./src/icons/dark/support-editable.svg"
        }
      },
      {
        "command": "v8vscedit.support.locked",
        "title": "На поддержке, редактирование запрещено",
        "icon": {
          "light": "./src/icons/light/support-locked.svg",
          "dark": "./src/icons/dark/support-locked.svg"
        }
      },
      {
        "command": "v8vscedit.repository.connect",
        "title": "Подключить к хранилищу",
        "icon": "$(plug)"
      },
      {
        "command": "v8vscedit.repository.create",
        "title": "Создать хранилище",
        "icon": "$(database)"
      },
      {
        "command": "v8vscedit.repository.disconnect",
        "title": "Отключить от хранилища",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "v8vscedit.repository.lock",
        "title": "Захватить в хранилище",
        "icon": "$(lock)"
      },
      {
        "command": "v8vscedit.repository.unlock",
        "title": "Освободить в хранилище",
        "icon": "$(unlock)"
      },
      {
        "command": "v8vscedit.repository.commit",
        "title": "Поместить в хранилище",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "v8vscedit.repository.update",
        "title": "Получить из хранилища",
        "icon": "$(cloud-download)"
      },
      {
        "command": "v8vscedit.repository.addUser",
        "title": "Добавить пользователя хранилища",
        "icon": "$(person-add)"
      },
      {
        "command": "v8vscedit.repository.copyUsers",
        "title": "Скопировать пользователей",
        "icon": "$(organization)"
      },
      {
        "command": "v8vscedit.repository.dump",
        "title": "Выгрузить конфигурацию из хранилища",
        "icon": "$(archive)"
      },
      {
        "command": "v8vscedit.repository.report",
        "title": "Построить отчет по хранилищу",
        "icon": "$(graph)"
      },
      {
        "command": "v8vscedit.repository.setLabel",
        "title": "Установить метку версии",
        "icon": "$(tag)"
      }
    ],
    "submenus": [
      {
        "id": "v8vscedit.repositoryMenu",
        "label": "Хранилище конфигурации"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "v8vscedit.refresh",
          "when": "view == v8vsceditTree",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "v8vscedit.connectExtension",
          "when": "view == v8vsceditTree && viewItem =~ /^extensions-root/",
          "group": "inline"
        },
        {
          "command": "v8vscedit.showConfigActions",
          "when": "view == v8vsceditTree && viewItem =~ /^(configuration|extension)-hasXml/",
          "group": "navigation@0"
        },
        {
          "command": "v8vscedit.importConfigurationFromDb",
          "when": "view == v8vsceditTree && viewItem =~ /^(configuration|extension)-hasXml/",
          "group": "navigation@0"
        },
        {
          "command": "v8vscedit.updateConfigurationInDb",
          "when": "view == v8vsceditTree && viewItem =~ /^(configuration|extension)-hasXml/",
          "group": "navigation@0"
        },
        {
          "command": "v8vscedit.compileAndUpdateExtensionInDb",
          "when": "view == v8vsceditTree && viewItem =~ /^extension-hasXml/",
          "group": "navigation@0"
        },
        {
          "command": "v8vscedit.borrowToExtension",
          "when": "view == v8vsceditTree && v8vscedit.hasCfeEntries && viewItem =~ /-hasXml/ && !(viewItem =~ /^(configuration|extension|extensions-root|group-)/) && !(viewItem =~ /-fromCfe/) && !(viewItem =~ /-repoEditRestricted/)",
          "group": "borrow@1"
        },
        {
          "command": "v8vscedit.openXmlFile",
          "when": "view == v8vsceditTree && viewItem =~ /-hasXml/ && !(viewItem =~ /-repoEditRestricted/)",
          "group": "navigation@1"
        },
        {
          "command": "v8vscedit.openObjectModule",
          "when": "view == v8vsceditTree && viewItem =~ /^(Catalog|Document|Report|DataProcessor|BusinessProcess|Task|ExchangePlan|ChartOfCharacteristicTypes|ChartOfAccounts|ChartOfCalculationTypes)-hasXml/ && !(viewItem =~ /-repoEditRestricted/)",
          "group": "navigation@2"
        },
        {
          "command": "v8vscedit.openManagerModule",
          "when": "view == v8vsceditTree && viewItem =~ /^(Catalog|Document|Report|DataProcessor|InformationRegister|AccumulationRegister|AccountingRegister|CalculationRegister|BusinessProcess|Task|ExchangePlan|ChartOfCharacteristicTypes|ChartOfAccounts|ChartOfCalculationTypes|Enum|DocumentJournal)-hasXml/ && !(viewItem =~ /-repoEditRestricted/)",
          "group": "navigation@2"
        },
        {
          "command": "v8vscedit.openRecordSetModule",
          "when": "view == v8vsceditTree && viewItem =~ /^(InformationRegister|AccumulationRegister|AccountingRegister|CalculationRegister)-hasXml/ && !(viewItem =~ /-repoEditRestricted/)",
          "group": "navigation@2"
        },
        {
          "command": "v8vscedit.openConstantModule",
          "when": "view == v8vsceditTree && viewItem =~ /^Constant-hasXml/ && !(viewItem =~ /-repoEditRestricted/)",
          "group": "navigation@2"
        },
        {
          "command": "v8vscedit.openFormModule",
          "when": "view == v8vsceditTree && viewItem =~ /^(CommonForm|Form)-hasXml/ && !(viewItem =~ /-repoEditRestricted/)",
          "group": "navigation@3"
        },
        {
          "command": "v8vscedit.openCommandModule",
          "when": "view == v8vsceditTree && viewItem =~ /^(CommonCommand|Command)-hasXml/ && !(viewItem =~ /-repoEditRestricted/)",
          "group": "navigation@3"
        },
        {
          "command": "v8vscedit.openServiceModule",
          "when": "view == v8vsceditTree && viewItem =~ /^(WebService|HTTPService)-hasXml/ && !(viewItem =~ /-repoEditRestricted/)",
          "group": "navigation@3"
        },
        {
          "command": "v8vscedit.openCommonModuleCode",
          "when": "view == v8vsceditTree && viewItem =~ /^CommonModule-hasXml/ && !(viewItem =~ /-repoEditRestricted/)",
          "group": "navigation@2"
        },
        {
          "command": "v8vscedit.showProperties",
          "when": "view == v8vsceditTree && viewItem =~ /-hasXml/ && !(viewItem =~ /-propertiesHidden/)",
          "group": "inline"
        },
        {
          "command": "v8vscedit.support.none",
          "when": "view == v8vsceditTree && viewItem =~ /-support0/",
          "group": "inline"
        },
        {
          "command": "v8vscedit.addMetadata",
          "when": "view == v8vsceditTree && viewItem =~ /-canAdd/ && !(viewItem =~ /-repoEditRestricted/)",
          "group": "inline"
        },
        {
          "command": "v8vscedit.removeMetadata",
          "when": "view == v8vsceditTree && viewItem =~ /-canRemove/ && !(viewItem =~ /-support2/) && !(viewItem =~ /-repoEditRestricted/)",
          "group": "inline"
        },
        {
          "command": "v8vscedit.removeMetadata",
          "when": "view == v8vsceditTree && viewItem =~ /-canRemove/ && !(viewItem =~ /-support2/) && !(viewItem =~ /-repoEditRestricted/)",
          "group": "navigation@10"
        },
        {
          "command": "v8vscedit.support.locked",
          "when": "view == v8vsceditTree && viewItem =~ /-support2/",
          "group": "inline"
        },
        {
          "command": "v8vscedit.support.editable",
          "when": "view == v8vsceditTree && viewItem =~ /-support1/",
          "group": "inline"
        },
        {
          "submenu": "v8vscedit.repositoryMenu",
          "when": "view == v8vsceditTree && viewItem =~ /^(configuration|extension)-hasXml/",
          "group": "navigation@20"
        },
        {
          "command": "v8vscedit.repository.lock",
          "when": "view == v8vsceditTree && viewItem =~ /-repoUnlocked/",
          "group": "inline"
        },
        {
          "command": "v8vscedit.repository.unlock",
          "when": "view == v8vsceditTree && viewItem =~ /-repoLocked/",
          "group": "inline"
        },
        {
          "command": "v8vscedit.repository.commit",
          "when": "view == v8vsceditTree && viewItem =~ /-repoConnected/ && !(viewItem =~ /^(extensions-root|group-common|group-type)/)",
          "group": "navigation@21"
        },
        {
          "command": "v8vscedit.repository.update",
          "when": "view == v8vsceditTree && viewItem =~ /-repoConnected/ && !(viewItem =~ /^extensions-root/)",
          "group": "navigation@21"
        }
      ],
      "v8vscedit.repositoryMenu": [
        {
          "command": "v8vscedit.repository.connect",
          "when": "view == v8vsceditTree && viewItem =~ /-repoDisconnected/",
          "group": "navigation@1"
        },
        {
          "command": "v8vscedit.repository.create",
          "when": "view == v8vsceditTree",
          "group": "navigation@2"
        },
        {
          "command": "v8vscedit.repository.disconnect",
          "when": "view == v8vsceditTree && viewItem =~ /-repoConnected/",
          "group": "navigation@3"
        },
        {
          "command": "v8vscedit.repository.addUser",
          "when": "view == v8vsceditTree && viewItem =~ /-repoConnected/",
          "group": "navigation@4"
        },
        {
          "command": "v8vscedit.repository.copyUsers",
          "when": "view == v8vsceditTree && viewItem =~ /-repoConnected/",
          "group": "navigation@5"
        },
        {
          "command": "v8vscedit.repository.dump",
          "when": "view == v8vsceditTree && viewItem =~ /-repoConnected/",
          "group": "navigation@6"
        },
        {
          "command": "v8vscedit.repository.report",
          "when": "view == v8vsceditTree && viewItem =~ /-repoConnected/",
          "group": "navigation@7"
        },
        {
          "command": "v8vscedit.repository.setLabel",
          "when": "view == v8vsceditTree && viewItem =~ /-repoConnected/",
          "group": "navigation@8"
        }
      ]
    },
    "grammars": [
      {
        "language": "bsl",
        "scopeName": "source.bsl",
        "path": "./syntaxes/bsl.tmLanguage.json"
      }
    ],
    "languages": [
      {
        "id": "bsl",
        "aliases": [
          "1C BSL",
          "1С"
        ],
        "extensions": [
          ".bsl",
          ".os"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "customEditors": [
      {
        "viewType": "v8vscedit.formEditor",
        "displayName": "Визуальный редактор формы 1С",
        "selector": [
          {
            "filenamePattern": "**/Ext/Form.xml"
          }
        ],
        "priority": "option"
      }
    ],
    "configurationDefaults": {
      "editor.semanticTokenColorCustomizations": {
        "rules": {
          "annotation:bsl": {
            "foreground": "#C678DD"
          },
          "preprocessor:bsl": {
            "foreground": "#A07850"
          },
          "function:bsl": {
            "foreground": "#DCDCAA"
          },
          "method:bsl": {
            "foreground": "#DCDCAA"
          },
          "parameter:bsl": {
            "foreground": "#9CDCFE"
          }
        }
      }
    },
    "configuration": {
      "title": "1С: Редактор конфигураций",
      "properties": {
        "v8vscedit.lsp.mode": {
          "type": "string",
          "default": "bsl-analyzer",
          "enum": [
            "bsl-analyzer",
            "off"
          ],
          "enumDescriptions": [
            "BSL Analyzer — внешний Rust-сервер (180+ диагностик, быстрый)",
            "Языковой сервер отключён"
          ],
          "description": "Режим языкового сервера BSL"
        },
        "v8vscedit.bslAnalyzer.autoUpdate": {
          "type": "boolean",
          "default": true,
          "description": "Автоматически проверять обновления bsl-analyzer при запуске"
        },
        "v8vscedit.bslAnalyzer.path": {
          "type": "string",
          "default": "",
          "description": "Путь к исполняемому файлу bsl-analyzer (если пусто — скачивается автоматически)"
        }
      }
    },
    "semanticTokenScopes": [
      {
        "language": "bsl",
        "scopes": {
          "comment": [
            "comment.line.double-slash"
          ],
          "string": [
            "string.quoted.double"
          ],
          "keyword": [
            "keyword.control"
          ],
          "number": [
            "constant.numeric"
          ],
          "operator": [
            "keyword.operator"
          ],
          "function": [
            "entity.name.function"
          ],
          "method": [
            "entity.name.function.member"
          ],
          "variable": [
            "variable.other.readwrite"
          ],
          "parameter": [
            "variable.parameter"
          ],
          "property": [
            "variable.other.property"
          ],
          "class": [
            "entity.name.type"
          ],
          "annotation": [
            "support.function"
          ],
          "preprocessor": [
            "entity.name.type"
          ]
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "compile": "tsc -p ./",
    "lint": "eslint . --max-warnings=0",
    "test": "node ./out/test/runTests.js",
    "pretest": "npm run compile && webpack --mode development"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "eslint": "^10.3.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.59.1",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.6",
    "iconv-lite": "^0.7.2",
    "vscode-languageclient": "^9.0.1"
  }
}
