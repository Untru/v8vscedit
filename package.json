{
  "name": "1c-metadata-navigator",
  "displayName": "1С: Навигатор метаданных",
  "description": "Навигатор по дереву метаданных конфигураций и расширений 1С:Предприятие (XML-выгрузка)",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/Configuration.xml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "1c-navigator",
          "title": "1С Метаданные",
          "icon": "src/icons/activity-bar.svg"
        }
      ]
    },
    "views": {
      "1c-navigator": [
        {
          "id": "1cMetadataTree",
          "name": "Метаданные"
        }
      ]
    },
    "commands": [
      {
        "command": "1cNavigator.refresh",
        "title": "Обновить",
        "icon": "$(refresh)"
      },
      {
        "command": "1cNavigator.openFile",
        "title": "Открыть файл"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "1cNavigator.refresh",
          "when": "view == 1cMetadataTree",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "compile": "tsc -p ./",
    "test": "node ./dist/test/runTests.js",
    "pretest": "webpack --mode development"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  }
}
