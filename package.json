{
  "name": "1c-metadata-navigator",
  "displayName": "1С: Навигатор метаданных",
  "description": "Навигатор по дереву метаданных конфигураций и расширений 1С:Предприятие (XML-выгрузка)",
  "version": "0.1.2",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "1c-navigator",
          "title": "1С Метаданные",
          "icon": "src/icons/activity-bar.svg"
        }
      ]
    },
    "views": {
      "1c-navigator": [
        {
          "id": "1cMetadataTree",
          "name": "Метаданные"
        }
      ]
    },
    "commands": [
      {
        "command": "1cNavigator.refresh",
        "title": "Обновить",
        "icon": "$(refresh)"
      },
      {
        "command": "1cNavigator.openXmlFile",
        "title": "Открыть XML"
      },
      {
        "command": "1cNavigator.openObjectModule",
        "title": "Открыть модуль объекта"
      },
      {
        "command": "1cNavigator.openManagerModule",
        "title": "Открыть модуль менеджера"
      },
      {
        "command": "1cNavigator.openFormModule",
        "title": "Открыть модуль формы"
      },
      {
        "command": "1cNavigator.openCommandModule",
        "title": "Открыть модуль команды"
      },
      {
        "command": "1cNavigator.openConstantModule",
        "title": "Открыть модуль константы"
      },
      {
        "command": "1cNavigator.openServiceModule",
        "title": "Открыть модуль сервиса"
      },
      {
        "command": "1cNavigator.openCommonModuleCode",
        "title": "Открыть модуль"
      },
      {
        "command": "1cNavigator.showProperties",
        "title": "Свойства"
      },
      {
        "command": "1cNavigator.bslAnalyzer.showMenu",
        "title": "BSL Analyzer: Меню"
      },
      {
        "command": "1cNavigator.bslAnalyzer.restart",
        "title": "BSL Analyzer: Перезапустить"
      },
      {
        "command": "1cNavigator.bslAnalyzer.update",
        "title": "BSL Analyzer: Проверить обновления"
      },
      {
        "command": "1cNavigator.bslAnalyzer.showOutput",
        "title": "BSL Analyzer: Показать лог"
      },
      {
        "command": "1cNavigator.support.none",
        "title": "Не на поддержке",
        "icon": {
          "light": "./src/icons/light/support-none.svg",
          "dark": "./src/icons/dark/support-none.svg"
        }
      },
      {
        "command": "1cNavigator.support.editable",
        "title": "На поддержке, редактирование разрешено",
        "icon": {
          "light": "./src/icons/light/support-editable.svg",
          "dark": "./src/icons/dark/support-editable.svg"
        }
      },
      {
        "command": "1cNavigator.support.locked",
        "title": "На поддержке, редактирование запрещено",
        "icon": {
          "light": "./src/icons/light/support-locked.svg",
          "dark": "./src/icons/dark/support-locked.svg"
        }
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "1cNavigator.refresh",
          "when": "view == 1cMetadataTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "1cNavigator.openXmlFile",
          "when": "view == 1cMetadataTree && viewItem =~ /-hasXml/",
          "group": "navigation@1"
        },
        {
          "command": "1cNavigator.openObjectModule",
          "when": "view == 1cMetadataTree && viewItem =~ /(Catalog|Document|Report|DataProcessor|InformationRegister|AccumulationRegister|AccountingRegister|CalculationRegister|BusinessProcess|Task|ExchangePlan|ChartOfCharacteristicTypes|ChartOfAccounts|ChartOfCalculationTypes)-hasXml/",
          "group": "navigation@2"
        },
        {
          "command": "1cNavigator.openManagerModule",
          "when": "view == 1cMetadataTree && viewItem =~ /(Catalog|Document|Report|DataProcessor|InformationRegister|AccumulationRegister|AccountingRegister|CalculationRegister|BusinessProcess|Task|ExchangePlan|ChartOfCharacteristicTypes|ChartOfAccounts|ChartOfCalculationTypes|Enum|DocumentJournal)-hasXml/",
          "group": "navigation@2"
        },
        {
          "command": "1cNavigator.openConstantModule",
          "when": "view == 1cMetadataTree && viewItem =~ /^Constant-hasXml/",
          "group": "navigation@2"
        },
        {
          "command": "1cNavigator.openFormModule",
          "when": "view == 1cMetadataTree && viewItem =~ /^(CommonForm|Form)-hasXml/",
          "group": "navigation@3"
        },
        {
          "command": "1cNavigator.openCommandModule",
          "when": "view == 1cMetadataTree && viewItem =~ /^(CommonCommand|Command)-hasXml/",
          "group": "navigation@3"
        },
        {
          "command": "1cNavigator.openServiceModule",
          "when": "view == 1cMetadataTree && viewItem =~ /^(WebService|HTTPService)-hasXml/",
          "group": "navigation@3"
        },
        {
          "command": "1cNavigator.openCommonModuleCode",
          "when": "view == 1cMetadataTree && viewItem =~ /^CommonModule-hasXml/",
          "group": "navigation@2"
        },
        {
          "command": "1cNavigator.showProperties",
          "when": "view == 1cMetadataTree && !(viewItem =~ /-propertiesHidden/)",
          "group": "navigation@9"
        },
        {
          "command": "1cNavigator.support.none",
          "when": "view == 1cMetadataTree && viewItem =~ /-support0/",
          "group": "inline"
        },
        {
          "command": "1cNavigator.support.locked",
          "when": "view == 1cMetadataTree && viewItem =~ /-support1/",
          "group": "inline"
        },
        {
          "command": "1cNavigator.support.editable",
          "when": "view == 1cMetadataTree && viewItem =~ /-support2/",
          "group": "inline"
        }
      ]
    },
    "grammars": [
      {
        "language": "bsl",
        "scopeName": "source.bsl",
        "path": "./syntaxes/bsl.tmLanguage.json"
      }
    ],
    "languages": [
      {
        "id": "bsl",
        "aliases": [
          "1C BSL",
          "1С"
        ],
        "extensions": [
          ".bsl",
          ".os"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configurationDefaults": {
      "editor.semanticTokenColorCustomizations": {
        "rules": {
          "annotation:bsl": {
            "foreground": "#C678DD"
          },
          "preprocessor:bsl": {
            "foreground": "#A07850"
          },
          "function:bsl": {
            "foreground": "#DCDCAA"
          },
          "method:bsl": {
            "foreground": "#DCDCAA"
          },
          "parameter:bsl": {
            "foreground": "#9CDCFE"
          }
        }
      }
    },
    "configuration": {
      "title": "1С: Навигатор метаданных",
      "properties": {
        "1cNavigator.lsp.mode": {
          "type": "string",
          "default": "built-in",
          "enum": ["built-in", "bsl-analyzer", "off"],
          "enumDescriptions": [
            "Встроенный LSP-сервер (tree-sitter, базовые возможности)",
            "BSL Analyzer — внешний Rust-сервер (180+ диагностик, быстрый)",
            "Языковой сервер отключён"
          ],
          "description": "Режим языкового сервера BSL"
        },
        "1cNavigator.bslAnalyzer.autoUpdate": {
          "type": "boolean",
          "default": true,
          "description": "Автоматически проверять обновления bsl-analyzer при запуске"
        },
        "1cNavigator.bslAnalyzer.path": {
          "type": "string",
          "default": "",
          "description": "Путь к исполняемому файлу bsl-analyzer (если пусто — скачивается автоматически)"
        }
      }
    },
    "semanticTokenScopes": [
      {
        "language": "bsl",
        "scopes": {
          "comment": [
            "comment.line.double-slash"
          ],
          "string": [
            "string.quoted.double"
          ],
          "keyword": [
            "keyword.control"
          ],
          "number": [
            "constant.numeric"
          ],
          "operator": [
            "keyword.operator"
          ],
          "function": [
            "entity.name.function"
          ],
          "method": [
            "entity.name.function.member"
          ],
          "variable": [
            "variable.other.readwrite"
          ],
          "parameter": [
            "variable.parameter"
          ],
          "property": [
            "variable.other.property"
          ],
          "class": [
            "entity.name.type"
          ],
          "annotation": [
            "support.function"
          ],
          "preprocessor": [
            "entity.name.type"
          ]
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "compile": "tsc -p ./",
    "test": "node ./dist/test/runTests.js",
    "pretest": "webpack --mode development"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "copy-webpack-plugin": "^12.0.2",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "tree-sitter-bsl": "^0.1.6",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "web-tree-sitter": "^0.25.10"
  }
}
