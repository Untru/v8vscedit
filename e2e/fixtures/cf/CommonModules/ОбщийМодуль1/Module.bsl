// Общий модуль для тестирования LSP-фич

Функция ПолучитьНаименование(Ссылка) Экспорт
	Возврат Строка(Ссылка);
КонецФункции

Процедура ОбработатьДанные(Данные, Режим = Неопределено) Экспорт
	Если Режим = "Полный" Тогда
		// Полная обработка
		Результат = ПолучитьНаименование(Данные);
		Сообщить(Результат);
	Иначе
		// Упрощённая обработка
		Сообщить(Строка(Данные));
	КонецЕсли;
КонецПроцедуры

Функция ВычислитьСумму(Цена, Количество, СтавкаНДС = 20) Экспорт
	Сумма = Цена * Количество;
	СуммаНДС = Сумма * СтавкаНДС / 100;
	Возврат Сумма + СуммаНДС;
КонецФункции
