{
  "Если": {
    "prefix": ["если", "if", "Если"],
    "body": [
      "Если ${1:Условие} Тогда",
      "\t$0",
      "КонецЕсли;"
    ],
    "description": "Если / КонецЕсли"
  },
  "Если Иначе": {
    "prefix": ["еслииначе", "ifelse", "ЕслиИначе"],
    "body": [
      "Если ${1:Условие} Тогда",
      "\t$2",
      "Иначе",
      "\t$0",
      "КонецЕсли;"
    ],
    "description": "Если / Иначе / КонецЕсли"
  },
  "Если ИначеЕсли": {
    "prefix": ["еслииначеесли", "ifelseif"],
    "body": [
      "Если ${1:Условие1} Тогда",
      "\t$2",
      "ИначеЕсли ${3:Условие2} Тогда",
      "\t$4",
      "Иначе",
      "\t$0",
      "КонецЕсли;"
    ],
    "description": "Если / ИначеЕсли / Иначе / КонецЕсли"
  },
  "Для Каждого": {
    "prefix": ["длякаждого", "foreach", "ДляКаждого"],
    "body": [
      "Для Каждого ${1:Элемент} Из ${2:Коллекция} Цикл",
      "\t$0",
      "КонецЦикла;"
    ],
    "description": "Для Каждого / Цикл"
  },
  "Для": {
    "prefix": ["для", "for", "Для"],
    "body": [
      "Для ${1:Счетчик} = ${2:0} По ${3:Количество} Цикл",
      "\t$0",
      "КонецЦикла;"
    ],
    "description": "Для / Цикл (с счётчиком)"
  },
  "Пока": {
    "prefix": ["пока", "while", "Пока"],
    "body": [
      "Пока ${1:Условие} Цикл",
      "\t$0",
      "КонецЦикла;"
    ],
    "description": "Пока / Цикл"
  },
  "Попытка": {
    "prefix": ["попытка", "try", "Попытка"],
    "body": [
      "Попытка",
      "\t$0",
      "Исключение",
      "\t// ${1:ИнформацияОбОшибке().Описание}",
      "КонецПопытки;"
    ],
    "description": "Попытка / Исключение / КонецПопытки"
  },
  "Процедура": {
    "prefix": ["проц", "proc", "Процедура"],
    "body": [
      "Процедура ${1:ИмяПроцедуры}(${2})",
      "\t$0",
      "КонецПроцедуры"
    ],
    "description": "Процедура / КонецПроцедуры"
  },
  "Функция": {
    "prefix": ["функ", "func", "Функция"],
    "body": [
      "Функция ${1:ИмяФункции}(${2})",
      "\t$0",
      "\tВозврат ${3:Результат};",
      "КонецФункции"
    ],
    "description": "Функция / КонецФункции"
  },
  "Процедура НаКлиенте": {
    "prefix": ["процклиент", "proclient"],
    "body": [
      "&НаКлиенте",
      "Процедура ${1:ИмяПроцедуры}(${2})",
      "\t$0",
      "КонецПроцедуры"
    ],
    "description": "&НаКлиенте Процедура"
  },
  "Процедура НаСервере": {
    "prefix": ["процсервер", "proserver"],
    "body": [
      "&НаСервере",
      "Процедура ${1:ИмяПроцедуры}(${2})",
      "\t$0",
      "КонецПроцедуры"
    ],
    "description": "&НаСервере Процедура"
  },
  "Процедура НаСервереБезКонтекста": {
    "prefix": ["процбк", "proservernc"],
    "body": [
      "&НаСервереБезКонтекста",
      "Функция ${1:ИмяФункции}(${2})",
      "\t$0",
      "\tВозврат ${3:Результат};",
      "КонецФункции"
    ],
    "description": "&НаСервереБезКонтекста Функция"
  },
  "Запрос": {
    "prefix": ["запрос", "query", "Запрос"],
    "body": [
      "Запрос = Новый Запрос;",
      "Запрос.Текст =",
      "\t\"ВЫБРАТЬ",
      "\t|\t${1:Поля}",
      "\t|ИЗ",
      "\t|\t${2:Таблица} КАК ${3:Псевдоним}\";",
      "",
      "${0:Результат = Запрос.Выполнить().Выгрузить();}"
    ],
    "description": "Новый Запрос с текстом"
  },
  "Запрос с параметрами": {
    "prefix": ["запроспар", "queryparam"],
    "body": [
      "Запрос = Новый Запрос;",
      "Запрос.Текст =",
      "\t\"ВЫБРАТЬ",
      "\t|\t${1:Поля}",
      "\t|ИЗ",
      "\t|\t${2:Таблица} КАК ${3:Псевдоним}",
      "\t|ГДЕ",
      "\t|\t${4:Условие} = &${5:Параметр}\";",
      "",
      "Запрос.УстановитьПараметр(\"${5:Параметр}\", ${6:Значение});",
      "",
      "${0:Результат = Запрос.Выполнить().Выгрузить();}"
    ],
    "description": "Запрос с параметрами"
  },
  "ПриСозданииНаСервере": {
    "prefix": ["присоздании", "oncreate"],
    "body": [
      "&НаСервере",
      "Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)",
      "\t$0",
      "КонецПроцедуры"
    ],
    "description": "Обработчик ПриСозданииНаСервере"
  },
  "ПриОткрытии": {
    "prefix": ["приоткрытии", "onopen"],
    "body": [
      "&НаКлиенте",
      "Процедура ПриОткрытии(Отказ)",
      "\t$0",
      "КонецПроцедуры"
    ],
    "description": "Обработчик ПриОткрытии"
  },
  "ПередЗаписью": {
    "prefix": ["передзаписью", "beforewrite"],
    "body": [
      "&НаКлиенте",
      "Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)",
      "\t$0",
      "КонецПроцедуры"
    ],
    "description": "Обработчик ПередЗаписью (клиент)"
  },
  "ПослеЗаписи": {
    "prefix": ["послезаписи", "afterwrite"],
    "body": [
      "&НаКлиенте",
      "Процедура ПослеЗаписи(ПараметрыЗаписи)",
      "\t$0",
      "КонецПроцедуры"
    ],
    "description": "Обработчик ПослеЗаписи (клиент)"
  },
  "ОбработкаЗаполнения": {
    "prefix": ["обрзаполн", "filling"],
    "body": [
      "Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)",
      "\t$0",
      "КонецПроцедуры"
    ],
    "description": "Обработчик ОбработкаЗаполнения (модуль объекта)"
  },
  "ОбработкаПроведения": {
    "prefix": ["обрпров", "posting"],
    "body": [
      "Процедура ОбработкаПроведения(Отказ, РежимПроведения)",
      "\t$0",
      "КонецПроцедуры"
    ],
    "description": "Обработчик ОбработкаПроведения (модуль объекта)"
  },
  "Область": {
    "prefix": ["область", "region"],
    "body": [
      "#Область ${1:ИмяОбласти}",
      "",
      "$0",
      "",
      "#КонецОбласти"
    ],
    "description": "#Область / #КонецОбласти"
  },
  "Область ОбработчикиСобытий": {
    "prefix": ["облсоб", "regionevents"],
    "body": [
      "#Область ОбработчикиСобытий",
      "",
      "$0",
      "",
      "#КонецОбласти"
    ],
    "description": "Область ОбработчикиСобытий"
  },
  "Область СлужебныеПроцедурыИФункции": {
    "prefix": ["облслуж", "regionprivate"],
    "body": [
      "#Область СлужебныеПроцедурыИФункции",
      "",
      "$0",
      "",
      "#КонецОбласти"
    ],
    "description": "Область СлужебныеПроцедурыИФункции"
  },
  "Структура модуля формы": {
    "prefix": ["модульформы", "formmodule"],
    "body": [
      "#Область ОбработчикиСобытийФормы",
      "",
      "&НаСервере",
      "Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)",
      "\t$0",
      "КонецПроцедуры",
      "",
      "#КонецОбласти",
      "",
      "#Область ОбработчикиСобытийЭлементовФормы",
      "",
      "#КонецОбласти",
      "",
      "#Область ОбработчикиКомандФормы",
      "",
      "#КонецОбласти",
      "",
      "#Область СлужебныеПроцедурыИФункции",
      "",
      "#КонецОбласти"
    ],
    "description": "Полная структура модуля формы с областями"
  },
  "Структура модуля объекта": {
    "prefix": ["модульобъекта", "objectmodule"],
    "body": [
      "#Область ОбработчикиСобытий",
      "",
      "$0",
      "",
      "#КонецОбласти",
      "",
      "#Область СлужебныеПроцедурыИФункции",
      "",
      "#КонецОбласти"
    ],
    "description": "Структура модуля объекта с областями"
  },
  "Оповестить": {
    "prefix": ["оповестить", "notify"],
    "body": [
      "ПоказатьОповещениеПользователя(",
      "\t${1:\"Заголовок\"},",
      "\t,",
      "\t${2:\"Текст оповещения\"},",
      "\tБиблиотекаКартинок.Информация32);"
    ],
    "description": "ПоказатьОповещениеПользователя"
  },
  "Сообщить": {
    "prefix": ["сообщить", "message"],
    "body": [
      "Сообщение = Новый СообщениеПользователю;",
      "Сообщение.Текст = ${1:\"Текст сообщения\"};",
      "${0:Сообщение.Сообщить();}"
    ],
    "description": "Новый СообщениеПользователю"
  },
  "НачатьТранзакцию": {
    "prefix": ["транзакция", "transaction"],
    "body": [
      "НачатьТранзакцию();",
      "Попытка",
      "\t$0",
      "\tЗафиксироватьТранзакцию();",
      "Исключение",
      "\tОтменитьТранзакцию();",
      "\tВызватьИсключение;",
      "КонецПопытки;"
    ],
    "description": "Транзакция с Попыткой"
  },
  "ОписаниеОповещения": {
    "prefix": ["опоповещ", "notifydesc"],
    "body": [
      "ОписаниеОповещения = Новый ОписаниеОповещения(",
      "\t\"${1:ИмяПроцедуры}\",",
      "\tЭтотОбъект${2:,",
      "\t${3:ДополнительныеПараметры}});"
    ],
    "description": "Новый ОписаниеОповещения"
  }
}
